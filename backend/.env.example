# ============================================================
# B2B Vendor & Retailer Management Platform — Environment Config
# Project Code: AMB-DMP-2026
# ============================================================

# --- Application ---
APP_NAME=AMB-DMP-2026
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amb_dmp_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-strong-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OTP ---
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# --- SMS Provider (MSG91 / Twilio) ---
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=AMBDMP
MSG91_TEMPLATE_ID=your-template-id
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Payment Gateway (Razorpay) ---
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Firebase Cloud Messaging ---
FCM_SERVER_KEY=your-fcm-server-key
FCM_CREDENTIALS_PATH=./firebase-credentials.json

# --- WhatsApp Business API ---
WHATSAPP_PROVIDER=interakt
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_API_URL=https://api.interakt.ai/v1

# --- File Storage (S3 / Supabase Storage) ---
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=amb-dmp-uploads
AWS_S3_REGION=ap-south-1

# --- Redis (optional, for token blacklist) ---
REDIS_URL=redis://localhost:6379/0

# --- Super Admin Seed ---
SUPER_ADMIN_EMAIL=admin@ambdmp.com
SUPER_ADMIN_PASSWORD=change-me-on-first-login
SUPER_ADMIN_MOBILE=+919999999999

# --- Backup ---
BACKUP_S3_BUCKET=amb-dmp-backups
BACKUP_RETENTION_DAYS=7

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
